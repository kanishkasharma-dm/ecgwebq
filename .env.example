# ECGWebQ Environment Variables Example
# Copy this to .env.local and update with your values

# Backend API base URLs
VITE_ADMIN_AUTH_BASE_URL=https://your-admin-auth-api.execute-api.us-east-1.amazonaws.com
VITE_ADMIN_PROTECTED_API_BASE_URL=https://your-admin-protected-api.execute-api.us-east-1.amazonaws.com
VITE_DOCTOR_API_BASE_URL=https://your-doctor-api.execute-api.us-east-1.amazonaws.com

# Exact backend route paths
VITE_ADMIN_LOGIN_PATH=/admin/login
VITE_ADMIN_UPLOAD_PATH=/prod/api/upload
VITE_ADMIN_REPORT_PATH=/prod/api/report
VITE_ADMIN_REPORTS_PATH=/prod/api/reports
VITE_ADMIN_S3_FILES_PATH=/prod/api/s3-files
VITE_ADMIN_S3_FILE_CONTENT_PATH=/prod/api/s3-file-content
VITE_CREATE_DOCTOR_PATH=/prod/api/admin/create-doctor
VITE_ADMIN_GET_DOCTORS_PATH=/prod/api/admin/doctor
VITE_DOCTOR_LOGIN_PATH=/admin/doctor/login
VITE_DOCTOR_REPORTS_PATH=/api/doctor/reports
VITE_DOCTOR_VALIDATE_INVITE_PATH=/doctor/validate-invite
VITE_DOCTOR_SET_PASSWORD_PATH=/doctor/set-password
VITE_DOCTOR_UPLOAD_REVIEWED_PATH=/api/doctor/upload-reviewed

# Admin Credentials
VITE_ADMIN_USERNAME=your_admin_username
VITE_ADMIN_PASSWORD=your_secure_password

# Security Settings
VITE_ENABLE_CSP=true
VITE_TOKEN_EXPIRY_CHECK=true
